```gitignore
# ==========================================================
# Dependencies
# ==========================================================
node_modules/
jspm_packages/
bower_components/
.claude

# ==========================================================
# Environment Variables (Never commit secrets)
# ==========================================================
.env
.env.*
!.env.example
!.env.local.example

# ==========================================================
# Build Outputs
# ==========================================================
.next/
out/
dist/
build/
coverage/
.vercel/

# ==========================================================
# Logs
# ==========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================================
# Runtime Files
# ==========================================================
pids/
*.pid
*.seed
*.pid.lock

# ==========================================================
# Cache
# ==========================================================
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.npm/
.yarn/
.pnp.*
*.tsbuildinfo

# ==========================================================
# Testing
# ==========================================================
.nyc_output/
coverage/

# ==========================================================
# Database Files
# ==========================================================
*.sqlite
*.sqlite3
*.db
*.mdb

# ==========================================================
# Uploads / Temporary Files
# (Remove this if uploads should be version controlled)
# ==========================================================
uploads/
tmp/
temp/

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ==========================================================
# IDE / Editor
# ==========================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.iml

# ==========================================================
# Package Manager
# ==========================================================
package-lock.json.orig
yarn.lock.orig
pnpm-lock.yaml.orig

# ==========================================================
# Docker
# ==========================================================
.dockerignore

# ==========================================================
# Local Config
# ==========================================================
.local/
config/local.*
*.local

# ==========================================================
# Certificates / Keys
# ==========================================================
*.pem
*.key
*.crt
*.pfx

# ==========================================================
# Archives
# ==========================================================
*.zip
*.tar
*.gz
*.7z
*.rar

# ==========================================================
# Backup Files
# ==========================================================
*.bak
*.backup
*.old

# ==========================================================
# Miscellaneous
# ==========================================================
*.tmp
*.temp

# ==========================================================
# Optional: Ignore generated public assets
# Uncomment if applicable
# ==========================================================
# public/generated/
# public/uploads/
# public/cache/
```
